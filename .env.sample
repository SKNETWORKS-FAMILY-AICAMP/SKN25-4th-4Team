# ── OpenAI (필수) ──
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ── NCBI / PubMed (필수) ──
NCBI_EMAIL=your@email.com
NCBI_API_KEY=

# ── Tavily (선택 — 없으면 웹검색 fallback 비활성화) ──
TAVILY_API_KEY=

# ── ChromaDB ──
CHROMA_DB_PATH=./data/chroma
PAPER_COLLECTION=biorag_papers
AUX_COLLECTION=biorag_aux

# ── Retrieval 파라미터 ──
PAPER_K=5
PAPER_FETCH_K=15
AUX_K=3
AUX_FETCH_K=8
MMR_LAMBDA=0.5

# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=info

# ── Frontend → Backend 연결 ──
BACKEND_URL=http://localhost:8000
